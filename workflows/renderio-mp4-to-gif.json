              "defaultValue": "https://media.renderio.dev/sample.avi",
              "requiredField": true
            }
          ]
        },
        "responseMode": "lastNode",
        "formDescription": "Enter a video URL to convert it to GIF using RenderIO"
      },
      "executeOnce": true,
      "typeVersion": 2.3,
      "alwaysOutputData": false
    },
    {
