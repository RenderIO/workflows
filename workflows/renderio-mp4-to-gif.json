      "name": "Render MP4 to GIF",
      "type": "n8n-nodes-renderio.renderio",
      "position": [
        2032,
        312
      ],
      "parameters": {
        "inputFiles": {
          "fileValues": [
            {
              "key": "in_video",
              "value": "={{ $json[\"Video URL\"] }}"
            }
          ]
        },
        "outputFiles": {
          "fileValues": [
            {
              "key": "out_gif",
              "value": "output.gif"
            }
          ]
        },
        "ffmpegCommand": "-i {{in_video}} {{out_gif}}"
      },
      "credentials": {
        "renderioApi": {
          "id": "B8t9mmexnXdcf0Fq",
          "name": "RenderIO account"
        }
      },
      "typeVersion": 1
